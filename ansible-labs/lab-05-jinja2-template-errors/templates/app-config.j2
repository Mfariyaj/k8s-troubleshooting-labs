# Application Configuration
# Generated by Ansible - DO NOT EDIT MANUALLY

[application]
name = {{ app_name }}
version = {{ app_version }}
environment = {{ environment }}

[database]
host = {{ db_host }}
port = {{ db_port }}
name = {{ db_name }}

[features]
{% for feature in enabled_features %}
{# BUG: 'item.name' is wrong - enabled_features is a flat list of strings, not dicts #}
{{ item.name }} = enabled
{% endforeach %}
{# BUG: should be '{% endfor %}' not '{% endforeach %}' #}

[logging]
level = {{ log_level | default('INFO') }}
file = /var/log/{{ app_name }}/app.log
